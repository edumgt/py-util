{
  "name": "Python Network Advanced",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bullseye",

  // Forward the FastAPI uvicorn port so it opens automatically in the browser.
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "FastAPI (uvicorn)",
      "onAutoForward": "openBrowser"
    }
  },

  // Install Python dependencies as soon as the container is created.
  "postCreateCommand": "bash .devcontainer/post-create.sh",

  // Useful VS Code extensions for this project.
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.debugpy",
        "charliermarsh.ruff",
        "tamasfe.even-better-toml",
        "redhat.vscode-yaml",
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": ["tests"],
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff"
        }
      }
    }
  },

  // Run as the default non-root 'vscode' user provided by the base image.
  "remoteUser": "vscode"
}
