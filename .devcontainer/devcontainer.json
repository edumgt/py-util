{
  "name": "Python Network Advanced",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bullseye",

  // docker-in-docker: enables Docker daemon inside Codespaces so k3d (k3s in
  // Docker) can create a full Kubernetes cluster without VMware.
  // kubectl-helm-minikube: installs kubectl (helm/minikube disabled).
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "enableNonRootDocker": "true",
      "moby": "true"
    },
    "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
      "version": "latest",
      "helm": "none",
      "minikube": "none"
    }
  },

  // hostRequirements: pre-selects the minimum machine size when creating a
  // codespace (GitHub Codespaces 공식 지원 머신).  Users can override it.
  //
  // GitHub Codespaces 지원 머신 크기 (2025년 기준):
  //   2-core  /  4 GB RAM / 32 GB  ← 기본값, GitHub Free 120 core-hrs/월
  //   4-core  /  8 GB RAM / 32 GB  ← k3d k8s 검증 최소 권장 (30 hrs/월 free)
  //   8-core  / 16 GB RAM / 64 GB  ← 여유 있는 k8s 검증 (15 hrs/월 free)
  //  16-core  / 32 GB RAM / 128 GB
  //  32-core  / 64 GB RAM / 128 GB
  //
  // 무료 할당량(GitHub Free): 120 core-hours/월 = 4코어 기준 30 시간/월
  // 상세 내용: docs/CODESPACES.md "머신 크기" 섹션 참조
  "hostRequirements": {
    "cpus": 4,
    "memory": "8gb",
    "storage": "32gb"
  },

  // 8000  – FastAPI uvicorn (direct, no k8s)
  // 30500 – Harbor registry NodePort (via k3d port mapping)
  // 30800 – FastAPI NodePort       (via k3d port mapping)
  "forwardPorts": [8000, 30500, 30800],
  "portsAttributes": {
    "8000": {
      "label": "FastAPI (uvicorn 직접)",
      "onAutoForward": "openBrowser"
    },
    "30500": {
      "label": "Harbor registry (k8s NodePort)",
      "onAutoForward": "silent"
    },
    "30800": {
      "label": "FastAPI (k8s NodePort)",
      "onAutoForward": "notify"
    }
  },

  // Install Python deps + k3d after the container is created.
  "postCreateCommand": "bash .devcontainer/post-create.sh",

  // Useful VS Code extensions for this project.
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.debugpy",
        "charliermarsh.ruff",
        "tamasfe.even-better-toml",
        "redhat.vscode-yaml",
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": ["tests"],
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff"
        }
      }
    }
  },

  // Run as the default non-root 'vscode' user provided by the base image.
  "remoteUser": "vscode"
}
